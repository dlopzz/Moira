# Consumido por docker-compose.prod.yml para sustituir variables.
# Este archivo es DISTINTO de moira-api/.env (el de Laravel) - no confundir.

API_DOMAIN=api.moirabikinis.ar
WEB_DOMAIN=moirabikinis.ar
# Dominio alternativo (.com.ar) que sirve el mismo sitio, sin redirect
WEB_DOMAIN_ALT=moirabikinis.com.ar

DB_DATABASE=moira
DB_USERNAME=moira
DB_PASSWORD=__CHANGE_ME_STRONG_RANDOM__

NEXT_PUBLIC_API_URL=https://api.moirabikinis.ar/api/v1
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=__SITE_KEY_PLACEHOLDER__

# Gate de QA para moira-web (ver src/proxy.ts). Seteado -> todo el sitio pide
# login antes de mostrar cualquier página (valida contra usuarios admin de la
# API vía /api/v1/qa-access/verify). Vaciar esta variable y redeployar "web"
# cuando el sitio esté listo para lanzamiento público.
QA_AUTH_SECRET=__CHANGE_ME_RANDOM__
