APP_NAME=Moira
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.moirabikinis.ar
FRONTEND_URL=https://moirabikinis.ar

# Orígenes del front habilitados para CORS (lista separada por comas). Deben
# coincidir con WEB_DOMAIN / WEB_DOMAIN_ALT del deploy.
CORS_ALLOWED_ORIGINS=https://moirabikinis.ar,https://moirabikinis.com.ar,https://www.moirabikinis.com.ar

# Compartida con moira-web (mismo valor en ambos) para eximir su tráfico SSR del
# rate limit de catálogo. Generar con: openssl rand -hex 32
INTERNAL_API_KEY=

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=moira
DB_USERNAME=moira
DB_PASSWORD=__CHANGE_ME_STRONG_RANDOM__

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=__SMTP_HOST_PLACEHOLDER__
MAIL_PORT=587
MAIL_USERNAME=__SMTP_USER_PLACEHOLDER__
MAIL_PASSWORD=__SMTP_PASS_PLACEHOLDER__
MAIL_FROM_ADDRESS=no-reply@moirabikinis.ar
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

RECAPTCHA_SECRET_KEY=
